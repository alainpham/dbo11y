# Grafana Alloy — environment variables
# Copy to .env.alloy and fill in your values:
#   cp grafana/.env.alloy.example grafana/.env.alloy

# Target architecture: amd64 | arm64 | arm
ARCH=amd64

# Grafana Cloud — Prometheus (metrics)
GCLOUD_HOSTED_METRICS_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GCLOUD_HOSTED_METRICS_ID=

# Grafana Cloud — Loki (logs)
GCLOUD_HOSTED_LOGS_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GCLOUD_HOSTED_LOGS_ID=

# Scrape interval
GCLOUD_SCRAPE_INTERVAL=60s

# Grafana Cloud API key (Read+Write)
# Generate one at: https://grafana.com/orgs/<your-org>/api-keys
GCLOUD_RW_API_KEY=

# PostgreSQL DSN for the db-o11y monitoring user
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=disable
POSTGRES_DSN=postgresql://db-o11y:db_o11y_password@localhost:5432/crophealth?sslmode=disable
